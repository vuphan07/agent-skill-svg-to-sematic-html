# Optional — only needed for the AI layer of the verify step
# (`batch_check.py --ai` / `visual_diff.py --ai`). The deterministic visual diff
# runs fully offline without any key.
#
# Copy to `.env` and fill in, or set GEMINI_API_KEY in your environment.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Optional: override the vision model (default: gemini-2.5-flash)
# MULTIMODAL_MODEL=gemini-2.5-flash
